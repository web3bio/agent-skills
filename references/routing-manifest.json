{
  "version": 3,
  "base_url": "https://api.web3.bio",
  "method": "GET",
  "encoding": "encodeURIComponent(path segments)",
  "order": ["credential", "wallet", "profile_flow"],
  "key_request_line": "Please provide x-api-key (wallet endpoint only).",
  "key_policy": {
    "no_http_without_key": true,
    "single_line_only": true,
    "next_message_first_non_empty_line_as_key": true
  },
  "routes": {
    "credential": { "path": "credential/{identity}", "x_api_key": false, "response_platform": "none" },
    "wallet": { "path": "wallet/{identity}", "x_api_key": true, "response_platform": "none", "strict_shell_only": true },
    "profile_flow": {
      "single_full": "profile/{platform}/{identity}",
      "single_ns": "ns/{platform}/{identity}",
      "universal_full": "profile/{identity}",
      "universal_ns": "ns/{identity}",
      "universal_response_platform": "platform-routing:first-match"
    }
  }
}
